    <!-- Welcome / First Launch -->
    <string name="welcome_title">Merħba</string>
    <string name="welcome_sovereignty">Iċ-ċwievet tiegħek.\nL-assi tiegħek.\nIs-sovranità tiegħek.</string>
    <string name="welcome_desc">L-assi tiegħek MHUMIEX maħżuna f\'din l-app. Jeżistu fuq il-blockchain, kontrollati miċ-ċwievet privati tiegħek.\n\nDin l-app taħżen biss iċ-ċwievet tiegħek b\'mod sigur. Ma nistgħux naċċessaw l-assi tiegħek.\n\nNota: Xi tokens (USDC, USDT) jistgħu jiġu ffriżati mill-emittenti tagħhom. Għal sovranità massima, uża ETH nattiv jew tokens deċentralizzati.</string>
    <string name="welcome_warning_title">Iċ-ċwievet tiegħek = L-assi tiegħek</string>
    <string name="welcome_warning_desc">Jekk titlef iċ-ċwievet privati tiegħek jew taqsamhom ma\' xi ħadd, titlef il-kontroll fuq l-assi tiegħek b\'mod permanenti.\n\nM\'hemmx għażla ta\' rkupru. Ebda tim ta\' sapport ma jista\' jgħinek. Din hija n-natura tas-sjieda vera.\n\nŻomm dejjem backup sigur taċ-ċwievet tiegħek.</string>
    <string name="welcome_opensource">Software open source. Ivverifika, tiddefidax.</string>
    <string name="welcome_start">Nifhem, ejja nibdew</string>

