    <!-- Welcome / First Launch -->
    <string name="welcome_title">Қош келдіңіз</string>
    <string name="welcome_sovereignty">Сіздің кілттеріңіз.\nСіздің қаражатыңыз.\nСіздің егемендігіңіз.</string>
    <string name="welcome_desc">Сіздің қаражатыңыз бұл қосымшада САҚТАЛМАЙДЫ. Олар блокчейнде бар, сіздің жеке кілттеріңізбен басқарылады.\n\nБұл қосымша тек сіздің кілттеріңізді қауіпсіз сақтайды. Біз сіздің қаражатыңызға қол жеткізе алмаймыз.\n\nЕскертпе: Кейбір токендерді (USDC, USDT) олардың эмитенттері тоқтата алады. Максималды егемендік үшін негізгі ETH немесе орталықсыздандырылған токендерді пайдаланыңыз.</string>
    <string name="welcome_warning_title">Сіздің кілттеріңіз = Сіздің қаражатыңыз</string>
    <string name="welcome_warning_desc">Жеке кілттеріңізді жоғалтсаңыз немесе біреумен бөліссеңіз, қаражатыңызды бақылауды мәңгілікке жоғалтасыз.\n\nҚалпына келтіру мүмкіндігі жоқ. Ешбір қолдау тобы сізге көмектесе алмайды. Бұл шынайы меншіктің табиғаты.\n\nКілттеріңіздің қауіпсіз сақтық көшірмесін әрқашан сақтаңыз.</string>
    <string name="welcome_opensource">Ашық бастапқы код бағдарламасы. Сенбеңіз, тексеріңіз.</string>
    <string name="welcome_start">Түсіндім, бастайық</string>

