    <!-- Welcome / First Launch -->
    <string name="welcome_title">Selamat Datang</string>
    <string name="welcome_sovereignty">Kunci Anda.\nAset Anda.\nKedaulatan Anda.</string>
    <string name="welcome_desc">Aset Anda TIDAK disimpan di aplikasi ini. Mereka ada di blockchain, dikendalikan oleh kunci privat Anda.\n\nAplikasi ini hanya menyimpan kunci Anda dengan aman. Kami tidak dapat mengakses aset Anda.\n\nCatatan: Beberapa token (USDC, USDT) dapat dibekukan oleh penerbitnya. Untuk kedaulatan maksimum, gunakan ETH native atau token terdesentralisasi.</string>
    <string name="welcome_warning_title">Kunci Anda = Aset Anda</string>
    <string name="welcome_warning_desc">Jika Anda kehilangan kunci privat atau membagikannya kepada seseorang, Anda kehilangan kontrol atas aset Anda secara permanen.\n\nTidak ada opsi pemulihan. Tidak ada tim dukungan yang dapat membantu Anda. Ini adalah sifat kepemilikan sejati.\n\nSelalu simpan cadangan kunci Anda dengan aman.</string>
    <string name="welcome_opensource">Perangkat lunak sumber terbuka. Verifikasi, jangan percaya.</string>
    <string name="welcome_start">Saya mengerti, mari mulai</string>

