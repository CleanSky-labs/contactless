    <!-- Welcome / First Launch -->
    <string name="welcome_title">እንኳን ደህና መጡ</string>
    <string name="welcome_sovereignty">የእርስዎ ቁልፎች።\nየእርስዎ ገንዘብ።\nየእርስዎ ሉዓላዊነት።</string>
    <string name="welcome_desc">ገንዘብዎ በዚህ መተግበሪያ ውስጥ አይከማችም። በብሎክቼይን ላይ ይኖራሉ፣ በግል ቁልፎችዎ ቁጥጥር ስር።\n\nይህ መተግበሪያ ቁልፎችዎን በደህንነት ያከማቻል። ገንዘብዎን ማግኘት አንችልም።\n\nማስታወሻ: አንዳንድ ቶከኖች (USDC፣ USDT) በአውጪዎቻቸው ሊታገዱ ይችላሉ። ለከፍተኛ ሉዓላዊነት፣ ተፈጥሯዊ ETH ወይም ያልተማከሉ ቶከኖችን ይጠቀሙ።</string>
    <string name="welcome_warning_title">ቁልፎችዎ = ገንዘብዎ</string>
    <string name="welcome_warning_desc">የግል ቁልፎችዎን ካጡ ወይም ከሰው ጋር ካጋሩ፣ በገንዘብዎ ላይ ያለዎትን ቁጥጥር ዘላቂ ያጣሉ።\n\nየማገገሚያ አማራጭ የለም። የድጋፍ ቡድን ሊረዳዎ አይችልም። ይህ የእውነተኛ ባለቤትነት ባህሪ ነው።\n\nሁልጊዜ ደህንነቱ የተጠበቀ የቁልፎችዎ ምትኬ ያስቀምጡ።</string>
    <string name="welcome_opensource">ክፍት ምንጭ ሶፍትዌር። ያረጋግጡ፣ አይመኑ።</string>
