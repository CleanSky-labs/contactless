    <!-- Welcome / First Launch -->
    <string name="welcome_title">Siyakwamukela</string>
    <string name="welcome_sovereignty">Okhiye bakho.\nImali yakho.\nUbukhosi bakho.</string>
    <string name="welcome_desc">Imali yakho AYIGCINWA kule app. Ikhona ku-blockchain, ilawulwa ngokhiye bakho abangasese.\n\nLe app igcina kuphela okhiye bakho ngokuphepha. Asikwazi ukufinyelela imali yakho.\n\nQaphela: Amanye amathokheni (USDC, USDT) angamishwa ngabakhiphi bawo. Ukuze uthole ubukhosi obuphelele, sebenzisa i-ETH yemvelo noma amathokheni angenamnikazi.</string>
    <string name="welcome_warning_title">Okhiye bakho = Imali yakho</string>
    <string name="welcome_warning_desc">Uma ulahlekelwa yizikhiye zakho eziyimfihlo noma uzabelane nazo nothile, ulahlekelwa ukulawula imali yakho unomphela.\n\nAyikho indlela yokubuyisa. Ayikho ithimba losizo elingakusiza. Lena yimvelo yobunikazi bangempela.\n\nHlala unebhekhi ephephile yokhiye bakho.</string>
    <string name="welcome_opensource">Isoftware yomthombo ovulekile. Qinisekisa, ungathembi.</string>
    <string name="welcome_start">Ngiyaqonda, masiqale</string>

