    <!-- Welcome / First Launch -->
    <string name="welcome_title">স্বাগতম</string>
    <string name="welcome_sovereignty">আপনার কী।\nআপনার ফান্ড।\nআপনার সার্বভৌমত্ব।</string>
    <string name="welcome_desc">আপনার ফান্ড এই অ্যাপে সংরক্ষিত নেই। এগুলো ব্লকচেইনে আছে, আপনার প্রাইভেট কী দ্বারা নিয়ন্ত্রিত।\n\nএই অ্যাপ শুধুমাত্র আপনার কী নিরাপদে সংরক্ষণ করে। আমরা আপনার ফান্ডে অ্যাক্সেস করতে পারি না।\n\nনোট: কিছু টোকেন (USDC, USDT) তাদের ইস্যুয়ার দ্বারা ফ্রিজ করা যেতে পারে। সর্বোচ্চ সার্বভৌমত্বের জন্য, নেটিভ ETH বা বিকেন্দ্রীকৃত টোকেন ব্যবহার করুন।</string>
    <string name="welcome_warning_title">আপনার কী = আপনার ফান্ড</string>
    <string name="welcome_warning_desc">আপনি যদি আপনার প্রাইভেট কী হারান বা কারো সাথে শেয়ার করেন, আপনি স্থায়ীভাবে আপনার ফান্ডের নিয়ন্ত্রণ হারাবেন।\n\nকোনো রিকভারি অপশন নেই। কোনো সাপোর্ট টিম আপনাকে সাহায্য করতে পারবে না। এটাই প্রকৃত মালিকানার প্রকৃতি।\n\nসবসময় আপনার কী-র নিরাপদ ব্যাকআপ রাখুন।</string>
    <string name="welcome_opensource">ওপেন সোর্স সফটওয়্যার। যাচাই করুন, বিশ্বাস করবেন না।</string>
