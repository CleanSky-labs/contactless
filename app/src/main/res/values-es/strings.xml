    <!-- Welcome / First Launch -->
    <string name="welcome_title">Bienvenido</string>
    <string name="welcome_sovereignty">Tus claves.\nTus fondos.\nTu soberanía.</string>
    <string name="welcome_desc">Tus fondos NO están guardados en esta app. Existen en la blockchain, controlados por tus claves privadas.\n\nEsta app solo almacena tus claves de forma segura. Nosotros no podemos acceder a tus fondos.\n\nNota: Algunos tokens (USDC, USDT) pueden ser congelados por sus emisores. Para máxima soberanía, usa ETH nativo o tokens descentralizados.</string>
    <string name="welcome_warning_title">Tus claves = Tus fondos</string>
    <string name="welcome_warning_desc">Si pierdes tus claves privadas o las compartes con alguien, perderás el control de tus fondos permanentemente.\n\nNo hay opción de recuperación. Ningún equipo de soporte puede ayudarte. Esta es la naturaleza de la verdadera propiedad.\n\nMantén siempre una copia de seguridad de tus claves.</string>
    <string name="welcome_opensource">Software de código abierto. Verifica, no confíes.</string>
    <string name="welcome_start">Entendido, comenzar</string>

