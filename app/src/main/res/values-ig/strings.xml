    <!-- Welcome / First Launch -->
    <string name="welcome_title">Nnọọ</string>
    <string name="welcome_sovereignty">Igodo gị.\nEgo gị.\nIkike gị.</string>
    <string name="welcome_desc">Anaghị echekwa ego gị na ngwa a. Ha nọ na blockchain, n\'okpuru njikwa igodo nzuzo gị.\n\nNgwa a na-echekwa igodo gị n\'udo naanị. Anyị enweghị ike ịnweta ego gị.\n\nRịba ama: Ụfọdụ token (USDC, USDT) nwere ike ịkwụsị site n\'aka ndị mepụtara ha. Maka ikike kachasị, jiri ETH ma ọ bụ token ndị emezigharịghị.</string>
    <string name="welcome_warning_title">Igodo gị = Ego gị</string>
    <string name="welcome_warning_desc">Ọ bụrụ na ị tụfuo igodo nzuzo gị ma ọ bụ kesaa ha na onye ọzọ, ị ga-atụfu njikwa ego gị ruo mgbe ebighị ebi.\n\nEnweghị nhọrọ nweghachi. Enweghị otu nkwado nwere ike inyere gị aka. Nke a bụ ọdịdị nwe n\'ezie.\n\nNa-echekwa ndabere nchekwa nke igodo gị mgbe niile.</string>
    <string name="welcome_opensource">Ngwanrọ mepere emepe. Nyochaa, ekwenyela naanị.</string>
    <string name="welcome_start">Aghọtara m, ka anyị malite</string>

