    <!-- Welcome / First Launch -->
    <string name="welcome_title">Chào mừng</string>
    <string name="welcome_sovereignty">Khóa của bạn.\nTài sản của bạn.\nChủ quyền của bạn.</string>
    <string name="welcome_desc">Tài sản của bạn KHÔNG được lưu trữ trong ứng dụng này. Chúng tồn tại trên blockchain, được kiểm soát bởi khóa riêng của bạn.\n\nỨng dụng này chỉ lưu trữ khóa của bạn một cách an toàn. Chúng tôi không thể truy cập tài sản của bạn.\n\nLưu ý: Một số token (USDC, USDT) có thể bị đóng băng bởi nhà phát hành. Để có chủ quyền tối đa, hãy sử dụng ETH gốc hoặc các token phi tập trung.</string>
    <string name="welcome_warning_title">Khóa của bạn = Tài sản của bạn</string>
    <string name="welcome_warning_desc">Nếu bạn mất khóa riêng hoặc chia sẻ với ai đó, bạn sẽ mất quyền kiểm soát tài sản của mình vĩnh viễn.\n\nKhông có tùy chọn khôi phục. Không có đội ngũ hỗ trợ nào có thể giúp bạn. Đây là bản chất của quyền sở hữu thực sự.\n\nLuôn giữ bản sao lưu an toàn cho khóa của bạn.</string>
    <string name="welcome_opensource">Phần mềm mã nguồn mở. Xác minh, đừng tin.</string>
    <string name="welcome_start">Tôi hiểu, bắt đầu thôi</string>

