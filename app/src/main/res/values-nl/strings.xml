    <!-- Welcome / First Launch -->
    <string name="welcome_title">Welkom</string>
    <string name="welcome_sovereignty">Uw sleutels.\nUw tegoeden.\nUw soevereiniteit.</string>
    <string name="welcome_desc">Uw tegoeden worden NIET opgeslagen in deze app. Ze bestaan op de blockchain, beheerd door uw privésleutels.\n\nDeze app slaat alleen uw sleutels veilig op. Wij hebben geen toegang tot uw tegoeden.\n\nOpmerking: Sommige tokens (USDC, USDT) kunnen worden bevroren door hun uitgevers. Voor maximale soevereiniteit, gebruik native ETH of gedecentraliseerde tokens.</string>
    <string name="welcome_warning_title">Uw sleutels = Uw tegoeden</string>
    <string name="welcome_warning_desc">Als u uw privésleutels verliest of met iemand deelt, verliest u permanent de controle over uw tegoeden.\n\nEr is geen hersteloptie. Geen supportteam kan u helpen. Dit is de aard van echt eigendom.\n\nBewaar altijd een veilige back-up van uw sleutels.</string>
    <string name="welcome_opensource">Open source software. Verifieer, vertrouw niet.</string>
    <string name="welcome_start">Ik begrijp het, laten we beginnen</string>

