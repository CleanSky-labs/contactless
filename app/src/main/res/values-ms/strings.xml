    <!-- Welcome / First Launch -->
    <string name="welcome_title">Selamat Datang</string>
    <string name="welcome_sovereignty">Kunci anda.\nDana anda.\nKedaulatan anda.</string>
    <string name="welcome_desc">Dana anda TIDAK disimpan dalam aplikasi ini. Ia wujud di blockchain, dikawal oleh kunci peribadi anda.\n\nAplikasi ini hanya menyimpan kunci anda dengan selamat. Kami tidak dapat mengakses dana anda.\n\nNota: Sesetengah token (USDC, USDT) boleh dibekukan oleh pengeluar mereka. Untuk kedaulatan maksimum, gunakan ETH asli atau token terdesentralisasi.</string>
    <string name="welcome_warning_title">Kunci anda = Dana anda</string>
    <string name="welcome_warning_desc">Jika anda kehilangan kunci peribadi atau berkongsinya dengan seseorang, anda akan kehilangan kawalan dana secara kekal.\n\nTiada pilihan pemulihan. Tiada pasukan sokongan yang boleh membantu. Ini adalah sifat pemilikan sebenar.\n\nSentiasa simpan sandaran kunci anda dengan selamat.</string>
    <string name="welcome_opensource">Perisian sumber terbuka. Sahkan, jangan percaya.</string>
    <string name="welcome_start">Saya faham, mari mulakan</string>

