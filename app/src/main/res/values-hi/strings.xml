    <!-- Welcome / First Launch -->
    <string name="welcome_title">स्वागत है</string>
    <string name="welcome_sovereignty">आपकी कुंजियां।\nआपके फंड।\nआपकी संप्रभुता।</string>
    <string name="welcome_desc">आपके फंड इस ऐप में संग्रहीत नहीं हैं। वे ब्लॉकचेन पर मौजूद हैं, आपकी प्राइवेट कुंजियों द्वारा नियंत्रित।\n\nयह ऐप केवल आपकी कुंजियों को सुरक्षित रूप से संग्रहीत करता है। हम आपके फंड तक नहीं पहुंच सकते।\n\nनोट: कुछ टोकन (USDC, USDT) उनके जारीकर्ताओं द्वारा फ्रीज किए जा सकते हैं। अधिकतम संप्रभुता के लिए, नेटिव ETH या विकेंद्रीकृत टोकन का उपयोग करें।</string>
    <string name="welcome_warning_title">आपकी कुंजियां = आपके फंड</string>
    <string name="welcome_warning_desc">यदि आप अपनी प्राइवेट कुंजियां खो देते हैं या किसी के साथ साझा करते हैं, तो आप स्थायी रूप से अपने फंड का नियंत्रण खो देते हैं।\n\nकोई रिकवरी विकल्प नहीं है। कोई सपोर्ट टीम आपकी मदद नहीं कर सकती। यह सच्चे स्वामित्व की प्रकृति है।\n\nहमेशा अपनी कुंजियों का सुरक्षित बैकअप रखें।</string>
    <string name="welcome_opensource">ओपन सोर्स सॉफ्टवेयर। सत्यापित करें, भरोसा न करें।</string>
