    <!-- Welcome / First Launch -->
    <string name="welcome_title">Welcome</string>
    <string name="welcome_sovereignty">Your keys.\nYour funds.\nYour sovereignty.</string>
    <string name="welcome_desc">Your funds are NOT stored in this app. They exist on the blockchain, controlled by your private keys.\n\nThis app only stores your keys securely. We cannot access your funds.\n\nNote: Some tokens (USDC, USDT) can be frozen by their issuers. For maximum sovereignty, use native ETH or decentralized tokens.</string>
    <string name="welcome_warning_title">Your keys = Your funds</string>
    <string name="welcome_warning_desc">If you lose your private keys or share them with someone, you lose control of your funds permanently.\n\nThere is no recovery option. No support team can help you. This is the nature of true ownership.\n\nAlways keep a secure backup of your keys.</string>
    <string name="welcome_opensource">Open source software. Verify, don\'t trust.</string>
    <string name="welcome_start">I understand, let\'s start</string>

