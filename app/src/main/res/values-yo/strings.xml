    <!-- Welcome / First Launch -->
    <string name="welcome_title">Kaabo</string>
    <string name="welcome_sovereignty">Awọn bọtini rẹ.\nOwó rẹ.\nIjọba tirẹ.</string>
    <string name="welcome_desc">Owó rẹ ko wa ninu app yii. Wọn wa lori blockchain, labẹ iṣakoso awọn bọtini ikọkọ rẹ.\n\nApp yii nikan tọju awọn bọtini rẹ lailewu. A ko le wọle si owó rẹ.\n\nAkiyesi: Awọn token kan (USDC, USDT) le di nipasẹ awọn oluṣe wọn. Fun ijọba ti o ga julọ, lo ETH abinibi tabi awọn token ti o pin.</string>
    <string name="welcome_warning_title">Awọn bọtini rẹ = Owó rẹ</string>
    <string name="welcome_warning_desc">Ti o ba padanu awọn bọtini ikọkọ rẹ tabi pin wọn pẹlu ẹnikẹni, o padanu iṣakoso owó rẹ lailai.\n\nKo si aṣayan imularada. Ko si ẹgbẹ atilẹyin le ṣe iranlọwọ fun ọ. Eyi ni iseda nini tootọ.\n\nNigbagbogbo tọju afẹyinti aabo ti awọn bọtini rẹ.</string>
    <string name="welcome_opensource">Sọfitiwia orisun-ìmọ. Ṣayẹwo, maṣe gbagbọ nikan.</string>
    <string name="welcome_start">Mo loye, jẹ ki a bẹrẹ</string>

