    <!-- Welcome / First Launch -->
    <string name="welcome_title">Velkommen</string>
    <string name="welcome_sovereignty">Dine nøgler.\nDine midler.\nDin suverænitet.</string>
    <string name="welcome_desc">Dine midler opbevares IKKE i denne app. De eksisterer på blockchainen, kontrolleret af dine private nøgler.\n\nDenne app opbevarer kun dine nøgler sikkert. Vi kan ikke få adgang til dine midler.\n\nBemærk: Nogle tokens (USDC, USDT) kan fryses af udstederne. For maksimal suverænitet, brug ETH eller decentraliserede tokens.</string>
    <string name="welcome_warning_title">Dine nøgler = Dine midler</string>
    <string name="welcome_warning_desc">Hvis du mister dine private nøgler eller deler dem med nogen, mister du permanent kontrollen over dine midler.\n\nDer er ingen genoprettelsesmulighed. Intet supportteam kan hjælpe dig. Dette er ægte ejerskabs natur.\n\nHav altid en sikker sikkerhedskopi af dine nøgler.</string>
    <string name="welcome_opensource">Open source software. Verificer, stol ikke blindt.</string>
    <string name="welcome_start">Jeg forstår, lad os starte</string>

