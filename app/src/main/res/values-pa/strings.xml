    <!-- Welcome / First Launch -->
    <string name="welcome_title">ਜੀ ਆਇਆਂ ਨੂੰ</string>
    <string name="welcome_sovereignty">ਤੁਹਾਡੀਆਂ ਕੁੰਜੀਆਂ।\nਤੁਹਾਡੇ ਫੰਡ।\nਤੁਹਾਡੀ ਸੰਪੂਰਨਤਾ।</string>
    <string name="welcome_desc">ਤੁਹਾਡੇ ਫੰਡ ਇਸ ਐਪ ਵਿੱਚ ਸਟੋਰ ਨਹੀਂ ਹਨ। ਉਹ ਬਲਾਕਚੇਨ \'ਤੇ ਮੌਜੂਦ ਹਨ, ਤੁਹਾਡੀਆਂ ਪ੍ਰਾਈਵੇਟ ਕੁੰਜੀਆਂ ਦੁਆਰਾ ਨਿਯੰਤਰਿਤ।\n\nਇਹ ਐਪ ਸਿਰਫ਼ ਤੁਹਾਡੀਆਂ ਕੁੰਜੀਆਂ ਨੂੰ ਸੁਰੱਖਿਅਤ ਢੰਗ ਨਾਲ ਸਟੋਰ ਕਰਦੀ ਹੈ। ਅਸੀਂ ਤੁਹਾਡੇ ਫੰਡਾਂ ਤੱਕ ਪਹੁੰਚ ਨਹੀਂ ਕਰ ਸਕਦੇ।\n\nਨੋਟ: ਕੁਝ ਟੋਕਨ (USDC, USDT) ਉਹਨਾਂ ਦੇ ਜਾਰੀਕਰਤਾਵਾਂ ਦੁਆਰਾ ਫ੍ਰੀਜ਼ ਕੀਤੇ ਜਾ ਸਕਦੇ ਹਨ। ਵੱਧ ਤੋਂ ਵੱਧ ਸੰਪੂਰਨਤਾ ਲਈ, ਮੂਲ ETH ਜਾਂ ਵਿਕੇਂਦਰੀਕ੍ਰਿਤ ਟੋਕਨ ਵਰਤੋ।</string>
    <string name="welcome_warning_title">ਤੁਹਾਡੀਆਂ ਕੁੰਜੀਆਂ = ਤੁਹਾਡੇ ਫੰਡ</string>
    <string name="welcome_warning_desc">ਜੇਕਰ ਤੁਸੀਂ ਆਪਣੀਆਂ ਪ੍ਰਾਈਵੇਟ ਕੁੰਜੀਆਂ ਗੁਆ ਬੈਠਦੇ ਹੋ ਜਾਂ ਕਿਸੇ ਨਾਲ ਸਾਂਝੀਆਂ ਕਰਦੇ ਹੋ, ਤਾਂ ਤੁਸੀਂ ਆਪਣੇ ਫੰਡਾਂ ਦਾ ਕੰਟਰੋਲ ਹਮੇਸ਼ਾ ਲਈ ਗੁਆ ਦਿੰਦੇ ਹੋ।\n\nਕੋਈ ਰਿਕਵਰੀ ਵਿਕਲਪ ਨਹੀਂ ਹੈ। ਕੋਈ ਸਹਾਇਤਾ ਟੀਮ ਤੁਹਾਡੀ ਮਦਦ ਨਹੀਂ ਕਰ ਸਕਦੀ। ਇਹ ਅਸਲ ਮਾਲਕੀ ਦਾ ਸੁਭਾਅ ਹੈ।\n\nਹਮੇਸ਼ਾ ਆਪਣੀਆਂ ਕੁੰਜੀਆਂ ਦਾ ਸੁਰੱਖਿਅਤ ਬੈਕਅੱਪ ਰੱਖੋ।</string>
    <string name="welcome_opensource">ਓਪਨ ਸੋਰਸ ਸਾਫਟਵੇਅਰ। ਪ੍ਰਮਾਣਿਤ ਕਰੋ, ਭਰੋਸਾ ਨਾ ਕਰੋ।</string>
    <string name="welcome_start">ਮੈਂ ਸਮਝ ਗਿਆ, ਸ਼ੁਰੂ ਕਰੋ</string>

