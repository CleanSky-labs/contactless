    <!-- Welcome / First Launch -->
    <string name="welcome_title">Tere tulemast</string>
    <string name="welcome_sovereignty">Teie võtmed.\nTeie vahendid.\nTeie suveräänsus.</string>
    <string name="welcome_desc">Teie vahendid EI ole sellesse rakendusse salvestatud. Need eksisteerivad plokiahelas, kontrollib teie privaatvõtmeid.\n\nSee rakendus salvestab ainult teie võtmed turvaliselt. Me ei pääse teie vahenditele ligi.\n\nMärkus: Mõned tokenid (USDC, USDT) võivad olla nende emitentide poolt külmutatud. Maksimaalse suveräänsuse jaoks kasutage natiivset ETH-i või detsentraliseeritud tokeneid.</string>
    <string name="welcome_warning_title">Teie võtmed = Teie vahendid</string>
    <string name="welcome_warning_desc">Kui kaotate oma privaatvõtmed või jagate neid kellegagi, kaotate kontrolli oma vahendite üle jäädavalt.\n\nTaastamisvõimalust pole. Ükski tugimeeskond ei saa teid aidata. See on tõelise omandi olemus.\n\nHoidke alati oma võtmetest turvaline varukoopia.</string>
    <string name="welcome_opensource">Avatud lähtekoodiga tarkvara. Kontrollige, ärge usaldage.</string>
    <string name="welcome_start">Saan aru, alustame</string>

